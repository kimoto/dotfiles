theme = Iterm2 Solarized Dark
command = /bin/zsh -l -c "/opt/homebrew/bin/tmux new -A -s ghostty"
font-family = JetBrainsMono Nerd Font
font-family = Hiragino Sans W4
font-feature = -calt, -liga, -dlig
font-thicken = true
font-thicken-strength = 10
macos-option-as-alt = true
macos-titlebar-style = hidden
quick-terminal-animation-duration = 1000
keybind = global:f12=toggle_quick_terminal
keybind = ¥=text:\\
keybind = super+digit_1=text:\x1b1
keybind = super+digit_2=text:\x1b2
keybind = super+digit_3=text:\x1b3
keybind = super+digit_4=text:\x1b4
keybind = super+digit_5=text:\x1b5
keybind = super+digit_6=text:\x1b6
keybind = super+digit_7=text:\x1b7
keybind = super+digit_8=text:\x1b8
keybind = super+digit_9=text:\x1b9
keybind = super+shift+o=toggle_background_opacity

# Alt+数字はAeroSpaceのワークスペース切り替えに使うため素通しさせる
keybind = alt+digit_0=unbind
keybind = alt+digit_1=unbind
keybind = alt+digit_2=unbind
keybind = alt+digit_3=unbind
keybind = alt+digit_4=unbind
keybind = alt+digit_5=unbind
quit-after-last-window-closed = true
shell-integration = zsh
shell-integration-features = no-cursor,ssh-env,ssh-terminfo
clipboard-write = allow
cursor-opacity = 0.5
cursor-style-blink = true
background-opacity = 0.6
custom-shader = ./shaders/cursor_sweep.glsl
