# EditorConfig: https://editorconfig.org
# Editors honour these hints live; `editorconfig-checker` enforces a subset of
# them in lefthook + CI (see bin/lint_editorconfig.sh) so violations fail fast.
# Indentation rules below are editor hints only — the checker's indentation
# check is disabled (see .editorconfig-checker.json) to avoid a repo-wide
# reindent of existing files.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

# YAML/TOML/JSON conventionally use 2-space indent.
[*.{yml,yaml,toml,json,jsonc}]
indent_size = 2

# Shell/zsh: 2-space indent matches the existing bin/ scripts.
[{*.sh,*.zsh,.zshrc,.zshenv,.zprofile,.zlogin,.bashrc,.bash_profile}]
indent_size = 2

# Makefiles require literal tabs.
[Makefile]
indent_style = tab

# --- max_line_length exemptions -------------------------------------------
# These hold lines that are inherently long and cannot be wrapped without
# hurting clarity or breaking the format. Hygiene checks (trailing whitespace,
# final newline) still apply to all of them.

# Prose: don't hard-wrap Markdown, and keep trailing-space line breaks.
[*.md]
max_line_length = off
trim_trailing_whitespace = false

# JSON has no line-continuation, so long string values are unavoidable.
[*.json]
max_line_length = off

# tmux key-bindings and GLSL shader code are single atomic statements.
[.tmux.conf]
max_line_length = off

[*.glsl]
max_line_length = off

# vim 'statusline' is one atomic setting; vimscript continuation is awkward.
[.vimrc]
max_line_length = off

# Tool-installer / hook scripts: long release-download URLs and a long
# secret-matching regex that cannot be split.
[bin/install_check_tools.sh]
max_line_length = off

[bin/check_secret_files.sh]
max_line_length = off

[.claude/hooks/*.sh]
max_line_length = off

# Generated by `gh`; sheldon templates and zsh-abbr defs are atomic values.
[config/gh/config.yml]
max_line_length = off

[config/sheldon/plugins.toml]
max_line_length = off

[config/zsh-abbr/user-abbreviations]
max_line_length = off

# Neovim plugin/extension tables contain long atomic list literals.
[config/nvim/**.lua]
max_line_length = off
